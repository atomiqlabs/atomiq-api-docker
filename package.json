{
  "name": "atomiq-api-docker",
  "version": "1.0.0",
  "description": "atomiq-api-docker",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:api && npm run build:scripts",
    "build:api": "tsc -p tsconfig.api.json",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "start": "node dist/index.js",
    "dev": "ts-node --project tsconfig.api.json src/index.ts",
    "test:harness": "ts-node --project tsconfig.scripts.json scripts/test-harness.ts"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:atomiqlabs/atomiq-api-docker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@atomiqlabs/chain-solana": "github:atomiqlabs/atomiq-chain-solana#develop",
    "@atomiqlabs/chain-starknet": "github:atomiqlabs/atomiq-chain-starknet#develop",
    "@atomiqlabs/sdk": "github:atomiqlabs/atomiq-sdk#api",
    "@atomiqlabs/storage-sqlite": "github:atomiqlabs/atomiq-storage-sqlite#develop",
    "@scure/btc-signer": "1.7",
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "starknet": "^9.4.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
